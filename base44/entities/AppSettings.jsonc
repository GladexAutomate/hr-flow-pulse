{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique setting key, e.g. 'attendance_approved_webhook'"
    },
    "value": {
      "type": "string",
      "description": "Setting value"
    }
  },
  "required": [
    "key",
    "value"
  ]
}